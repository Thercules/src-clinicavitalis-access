#!/bin/sh
. "$(dirname "$0")/_/husky.sh"

echo "🧬 Verificando score de mutação com Stryker..."
echo "Isso pode levar alguns minutos..."

cd src/client
npm run test:mutation

if [ $? -ne 0 ]; then
  echo "❌ Teste de mutação falhou!"
  exit 1
fi

npm run test:mutation:check

if [ $? -ne 0 ]; then
  echo "❌ Score de mutação abaixo do threshold (80%)!"
  echo "💡 Abra reports/mutation/mutation.html para detalhes"
  exit 1
fi

echo "✅ Score de mutação aprovado! Prosseguindo com push..."
