{
  "name": "client",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node scripts/client_start_banner.js && vite",
    "build": "vite build",
    "preview": "vite preview",
    "test:unit": "vitest --run",
    "test:unit:ui": "vitest --ui",
    "test:unit:coverage": "vitest --run --coverage",
    "test:unit:watch": "vitest --watch",
    "test:component": "vitest --reporter=verbose",
    "test:mutation": "stryker run",
    "test:mutation:check": "stryker run --reporters=json && node scripts/check-mutation-score.js",
    "prepare": "cypress install",
    "test:e2e": "start-server-and-test preview http://localhost:4173 'cypress run --e2e'",
    "test:e2e:dev": "start-server-and-test 'vite dev --port 4173' http://localhost:4173 'cypress open --e2e'",
    "test:all": "npm run test:unit && npm run test:unit:coverage && npm run test:mutation",
    "lint": "eslint . --fix",
    "format": "prettier --write src/"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "lucide-vue-next": "^0.577.0",
    "pinia": "^2.3.1",
    "vue": "^3.5.13",
    "vue-i18n": "^11.3.0",
    "vue-router": "^4.5.0",
    "vue3-carousel": "^0.14.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@stryker-mutator/core": "^9.6.0",
    "@stryker-mutator/typescript-checker": "^9.6.0",
    "@stryker-mutator/vitest-runner": "^9.6.0",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vitejs/plugin-vue-jsx": "^4.1.1",
    "@vitest/coverage-v8": "^4.1.2",
    "@vitest/eslint-plugin": "1.1.25",
    "@vue/eslint-config-prettier": "^10.1.0",
    "@vue/test-utils": "^2.4.6",
    "cypress": "^14.0.1",
    "eslint": "^9.18.0",
    "eslint-plugin-cypress": "^4.1.0",
    "eslint-plugin-vue": "^9.32.0",
    "jsdom": "^26.0.0",
    "prettier": "^3.4.2",
    "start-server-and-test": "^2.0.10",
    "typescript": "^5.6.0",
    "vite": "^6.0.11",
    "vite-plugin-vue-devtools": "^7.7.1",
    "vitest": "^4.1.2"
  }
}
